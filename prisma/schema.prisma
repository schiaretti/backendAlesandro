// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model usuarios {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  email String @unique
  nome  String
  senha String
  nivel String
  postes Postes[]
}


model Postes {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  numeroIdentificacao String  @unique
  usuario            usuarios @relation(fields: [usuarioId], references: [id])
  usuarioId          String   @db.ObjectId
  latitude           Float?
  longitude          Float?
  cidade             String
  endereco           String
  numero             String
  cep                String
  isLastPost         Boolean  @default(false)
  localizacao        String?
   emFrente           String?
  transformador      String?
  medicao            String?
  telecom            String? 
  concentrador       String?
  poste              String?
  alturaposte        Float?   // Melhor como número
  estruturaposte     String?
  tipoBraco          String?
  tamanhoBraco       Float?   // Melhor como número
  quantidadePontos   Int?     // Melhor como inteiro
  tipoLampada        String?
  potenciaLampada    Int?     // Melhor como inteiro (watts)
  tipoReator         String?
  tipoComando        String?
  tipoRede           String?
  tipoCabo           String?
  numeroFases        String?    
  tipoVia            String?
  hierarquiaVia      String?
  tipoPavimento      String?
  quantidadeFaixas   Int?     // Melhor como inteiro
  tipoPasseio        String?
  canteiroCentral    Boolean? // Melhor como booleano
  finalidadeInstalacao String?
  
  
  // Relações
  fotos              Foto[]
  arvores            Arvore[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Arvore {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  poste       Postes   @relation(fields: [posteId], references: [id])
  posteId     String   @db.ObjectId
  especie     String
  latitude    Float
  longitude   Float
  fotos       FotoArvore[]
  descricao   String?
  createdAt   DateTime @default(now())
  @@index([posteId], name: "arvore_poste_index")
}

model Foto {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  url       String
  tipo      FotoTipo
  poste     Postes   @relation(fields: [posteId], references: [id])
  posteId   String   @db.ObjectId
  createdAt DateTime @default(now())
}

model FotoArvore {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  url       String
  arvore    Arvore   @relation(fields: [arvoreId], references: [id])
  arvoreId  String   @db.ObjectId
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
}

enum FotoTipo {
  PANORAMICA
  LUMINARIA
  TELECOM
  LAMPADA
  OUTRO
}